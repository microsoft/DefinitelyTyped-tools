{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "ignoreBinaries": ["only-allow"]
    },
    "packages/definitions-parser": {
      "project": "**/*.ts"
    },
    "packages/dts-critic": {
      "project": "**/*.ts"
    },
    "packages/dts-gen": {
      "project": "**/*.ts",
      "ignoreDependencies": ["ecurve", "jquery", "lodash"]
    },
    "packages/dtslint": {
      "project": "**/*.ts",
      "ignoreDependencies": [
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "@typescript-eslint/types",
        "@typescript-eslint/utils",
        "eslint-plugin-import"
      ]
    },
    "packages/dtslint-runner": {
      "entry": ["src/post-results.ts"],
      "project": "**/*.ts"
    },
    "packages/eslint-plugin": {
      "project": "**/*.ts",
      "ignoreDependencies": ["@definitelytyped/eslint-plugin"],
      "ignore": ["**/suggestions.ts"]
    },
    "packages/header-parser": {
      "project": "**/*.ts"
    },
    "packages/publisher": {
      "entry": [
        "src/calculate-versions.ts",
        "src/clean.ts",
        "src/full.ts",
        "src/generate-packages.ts",
        "src/get-definitely-typed.ts",
        "src/main.ts",
        "src/publish-packages.ts",
        "src/publish-registry.ts",
        "src/run.ts"
      ],
      "project": "**/*.ts"
    },
    "packages/retag": {
      "project": "**/*.ts"
    },
    "packages/typescript-packages": {
      "project": "**/*.ts",
      "ignoreDependencies": ["^typescript-.*"]
    },
    "packages/typescript-versions": {
      "project": "**/*.ts"
    },
    "packages/utils": {
      "project": "**/*.ts"
    },
    "packages/mergebot": {
      "entry": ["src/run.ts", "src/commands/create-fixture.ts", "src/commands/update-all-fixtures.ts", "src/commands/update-test-data.ts"],
      "project": "**/*.ts",
      "ignore": ["src/queries/schema/*.ts"]
    }
  },
  "ignore": ["**/fixtures/**", "**/testsource/**", "**/*.d.ts"],
  "ignoreExportsUsedInFile": true
}
